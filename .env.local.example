# ============================================================
# Klickhafen CRM — Umgebungsvariablen
# Kopiere diese Datei nach `.env.local` und trage deine Werte ein.
# `.env.local` ist in .gitignore — die Schlüssel landen NIE im Repo.
# In Vercel dieselben Variablen unter Settings → Environment Variables.
# ============================================================

# --- Supabase (Datenbank + Login) -------------------------------------------
# Findest du im Supabase-Dashboard unter Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-public-key

# --- Zugang zum CRM ---------------------------------------------------------
# NUR diese E-Mail darf sich anmelden. Lege in Supabase unter Authentication →
# Users einen Nutzer mit GENAU dieser E-Mail + einem Passwort an. Jede andere
# Adresse wird abgelehnt.
ADMIN_EMAIL=kontakt@klickhafen.com

# --- Resend (Rechnungsversand) ----------------------------------------------
# Nur für den PDF-Rechnungsversand nötig, nicht für den Login. Key aus
# resend.com → API Keys. Die Absender-Domain (klickhafen.com) muss in Resend
# verifiziert sein, sonst wird der Versand abgelehnt.
RESEND_API_KEY=re_dein_key
RESEND_FROM=Klickhafen <kontakt@klickhafen.com>

# --- Basis-URL --------------------------------------------------------------
# Lokal http://localhost:3000, live https://klickhafen.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
